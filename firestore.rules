rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /expenses/{expenseId} {
      // Allow user to see their own expenses
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      
      // Allow user to create an expense if they are the owner
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      
      // Allow user to update or delete if they own the expense
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /settings/{settingId} {
      // Allow user to read/write their own settings
      allow read, write: if isSignedIn() && (
        (resource != null && isOwner(resource.data.userId)) || 
        (resource == null && isOwner(request.resource.data.userId))
      );
    }
  }
}
